# Konfiguration des LLM-Modellselektors (automl_ad/llm.py).
# Diese Datei nach .env kopieren und ausfüllen. .env wird NICHT eingecheckt.

# --- Provider 1 (primär): Claude API ---------------------------------------------
# Wenn ein API-Key gesetzt ist, wird Claude verwendet.
ANTHROPIC_API_KEY=
# Modell (konfigurierbar; günstiger z. B. claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Provider 2 (Fallback): lokales Ollama ---------------------------------------
# Wird genutzt, wenn kein ANTHROPIC_API_KEY gesetzt ist.
# Modell muss lokal vorhanden sein:  ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
